{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/session_start_wakeup.py",
            "timeout": 45
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/universal-prompt-classifier.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .codex/hooks/user_prompt_capture.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .codex/hooks/continuity_prompt_context.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/pre_tool_guard.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/file_line_guard.py --event PostToolUse",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .codex/hooks/shaping_ripple.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .codex/hooks/post_tool_extract_memory.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .codex/hooks/post_tool_checkpoint.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .codex/hooks/post_tool_cost_ledger.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/anti-rationalization-stop.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/ralph-stop-quality-gate.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .codex/hooks/file_line_guard.py --event Stop",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "python3 scripts/gates/codex_stop_slop_guard.py",
            "timeout": 45
          },
          {
            "type": "command",
            "command": "python3 .codex/hooks/stop_route_decision_warn.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .codex/hooks/implementation_notes_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .codex/hooks/stop_persist_memory.py",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "python3 .codex/hooks/stop_memory_promotion_review.py",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
